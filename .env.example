# G0DM0D3 Environment Variables
# Copy to .env and fill in your values

# ── Required ──────────────────────────────────────────────
# OpenRouter API key — powers all model calls
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── Optional: Auth ────────────────────────────────────────
# API key(s) callers must send as Bearer token (comma-separated for multiple)
# Leave empty to allow unauthenticated access
# GODMODE_API_KEY=your-secret-key
# GODMODE_API_KEYS=key1,key2,key3

# ── Optional: Tier control ────────────────────────────────
# Map API keys to tiers: tier:key,tier:key
# GODMODE_TIER_KEYS=free:*,pro:sk-pro-key,enterprise:sk-enterprise-key

# ── Optional: HuggingFace dataset publishing ──────────────
# HF_TOKEN=hf_your-write-token
# HF_DATASET_REPO=your-username/your-dataset

# ── Optional: Ports ───────────────────────────────────────
# WEB_PORT=3000
# PROXY_PORT=80

# ── Optional: CORS ────────────────────────────────────────
# Set to * to allow all origins (useful behind reverse proxy)
# CORS_ORIGIN=*
